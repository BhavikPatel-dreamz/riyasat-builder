// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Page {
  id             String   @id @default(cuid())
  shop           String
  title          String
  slug           String
  html           String   @db.Text
  json           String   @db.Text
  status         String   @default("draft")
  // "page" | "header" | "footer" — headers and footers reuse the same builder
  // and are attached to pages via headerId / footerId.
  type           String   @default("page")
  // Layout settings consumed by the mobile app via the App Proxy.
  hideHeader      Boolean @default(false)
  showPageTitle   Boolean @default(true)
  backgroundColor String  @default("#ffffff")
  // "normal" | "scrollView" | "flatList"
  renderingType   String  @default("normal")
  // Optional references to header/footer-type pages (same shop).
  headerId       String?
  footerId       String?
  // Sticky (pinned) slots also reference reusable header/footer-type pages,
  // so a component can be built once and reused across pages. The legacy
  // inline `stickyHeader`/`stickyFooter` JSON columns are kept as a fallback
  // for any page saved before the switch to references.
  stickyHeaderId String?
  stickyFooterId String?
  stickyHeader   String   @default("[]") @db.Text
  stickyFooter   String   @default("[]") @db.Text
  description    String?  @db.Text
  seoTitle       String?
  seoDescription String?  @db.Text
  ogImage        String?
  keywords       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, slug])
  @@index([shop])
  @@index([shop, type])
}

model Media {
  id            String   @id @default(cuid())
  shop          String
  shopifyFileId String?
  url           String
  alt           String?
  title         String?
  mimeType      String?
  createdAt     DateTime @default(now())

  @@index([shop])
}

// Per-shop mobile app force-update settings (Settings page + app proxy).
model ForceUpdateConfig {
  shop                     String   @id
  androidAppVersion        String   @default("") @map("android_app_version")
  androidStoreUrl          String   @default("") @map("android_store_url")
  androidEnableForceUpdate Boolean  @default(false) @map("android_enable_force_update")
  iosAppVersion            String   @default("") @map("ios_app_version")
  iosStoreUrl              String   @default("") @map("ios_store_url")
  iosEnableForceUpdate     Boolean  @default(false) @map("ios_enable_force_update")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("force_update_config")
}

model ShopSettings {
  id                        String   @id @default(cuid())
  shop                      String   @unique
  androidAppVersion         String   @default("")
  androidPlayStoreUrl       String   @default("")
  androidForceUpdateEnabled Boolean  @default(false)
  iosAppVersion             String   @default("")
  iosAppStoreUrl            String   @default("")
  iosForceUpdateEnabled     Boolean  @default(false)
  backgroundMusicFileUrl    String   @default("")
  backgroundMusicUrl        String   @default("")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}


// Merchant-authored Gutenberg block, stored as pure JSON and registered
// dynamically in the editor via gutenberg-block-kit's blockRegistry. No JS
// code is stored — `schema` holds the attribute + field-control spec that the
// package's schema-driven factory turns into edit/save at runtime.
model BlockDefinition {
  id           String   @id @default(cuid())
  shop         String
  name         String   // "cms/hero-banner" — namespace/slug (unique per shop)
  title        String
  description  String?  @db.Text
  categorySlug String   @default("custom")
  icon         String   @default("smiley")
  previewImage String?  // Media.url — shown in the inserter
  keywords     String   @default("[]") @db.Text // JSON string[]
  supports     String   @default("{}")  @db.Text // JSON: { align, html, reusable }
  // Authoring payload consumed by buildBlockSettings():
  //   { attributes: {...}, fields: [ { key, control, label, panel, default, ... } ] }
  schema       String   @db.Text
  // "draft" | "enabled" | "disabled" — only "enabled" reach the editor registry.
  status       String   @default("draft")
  version      Int      @default(1)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions BlockVersion[]

  @@unique([shop, name])
  @@index([shop, status])
  @@index([shop, categorySlug])
}

// Merchant-created inserter category (Layout, Marketing, Products, …).
model BlockCategory {
  id        String   @id @default(cuid())
  shop      String
  slug      String   // "marketing"
  title     String   // "Marketing"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([shop, slug])
  @@index([shop])
}

// Immutable snapshot written on every BlockDefinition update.
model BlockVersion {
  id        String   @id @default(cuid())
  blockId   String
  version   Int
  snapshot  String   @db.Text // full BlockDefinition JSON at save time
  createdBy String?
  createdAt DateTime @default(now())

  block BlockDefinition @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, version])
  @@index([blockId])
}
